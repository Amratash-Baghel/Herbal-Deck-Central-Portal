# ---------------------------------------------------------------------------
# Herbal Deck Portal — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values from your Supabase
# project dashboard (Project Settings → API). Never commit ".env.local".
# ---------------------------------------------------------------------------

# Public project URL. Safe to expose to the browser.
# Supabase Dashboard → Project Settings → API → "Project URL"
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key. Safe to expose to the browser. Row Level Security (RLS)
# is what actually protects your data — not the secrecy of this key.
# Supabase Dashboard → Project Settings → API → "Project API keys" → "anon" "public"
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret service-role key. SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC,
# never expose to the browser. Used only by admin actions (e.g. inviting
# employees) to bypass RLS. Leave blank until you build admin features.
# Supabase Dashboard → Project Settings → API → "Project API keys" → "service_role" "secret"
SUPABASE_SERVICE_ROLE_KEY=
